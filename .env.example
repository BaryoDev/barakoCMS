# barakoCMS — environment for the all-in-one stack (docker-compose.hub.yml).
#   cp .env.example .env   (optional — the compose ships with working defaults for a local try-out)
#
#   docker compose -f docker-compose.hub.yml up -d
#   Admin UI -> http://localhost:3000    API -> http://localhost:5005
#   Sign in with ADMIN_USER / ADMIN_PASSWORD.
#
# NEVER commit your real .env to source control.

# --- Postgres ---
DB_NAME=barako_cms
DB_USER=postgres
DB_PASSWORD=postgres

# --- Security ---
# JWT signing key. MUST be at least 32 characters or the API refuses to start. Change for real use.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# First admin, seeded on first start (this is your admin-UI login).
ADMIN_USER=admin
ADMIN_PASSWORD=changeme-in-production

# --- Wiring ---
# The admin UI is a browser SPA, so this is the API URL as seen from your browser.
NEXT_PUBLIC_API_URL=http://localhost:5005

# --- Optional integrations (leave unset to skip) ---
# Email (Resend) — enables OTP email sign-in; falls back to a mock logger if unset.
# Resend__ApiKey=re_xxxxxxxx
# Resend__From=BarakoCMS <onboarding@resend.dev>
