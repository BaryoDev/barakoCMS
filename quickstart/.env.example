# ─────────────────────────────────────────────────────────────────────────────
# barakoCMS quickstart configuration.  cp .env.example .env  then edit.
# Only the "Required" block is needed to boot. Everything else is optional and
# stays off (or uses a safe mock) until you fill it in.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-to-a-strong-password
# JWT signing key — MUST be at least 32 characters, or the API won't start.
JWT_KEY=change-me-to-at-least-32-characters-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── URLs & ports ─────────────────────────────────────────────────────────────
# What the browser uses to reach the API. Behind a reverse proxy, set your public URL
# (e.g. https://cms.example.com) and add it to ALLOWED_ORIGINS.
PUBLIC_API_URL=http://localhost:5005
ALLOWED_ORIGINS=http://localhost:3000
API_PORT=5005
ADMIN_PORT=3000
# Pin a release instead of :latest for reproducible deploys, e.g. BARAKO_TAG=3.1.0
BARAKO_TAG=latest
# 'Development' relaxes some checks for local trials; use 'Production' for real deploys.
ASPNETCORE_ENVIRONMENT=Production

# ── Email — Resend module (optional) ─────────────────────────────────────────
# Leave blank to use the built-in mock (emails are logged, not sent).
RESEND_API_KEY=
RESEND_FROM=Your App <no-reply@yourdomain.com>
# For the delivery webhook (bounce/complaint tracking); from the Resend dashboard.
RESEND_WEBHOOK_SECRET=

# ── Analytics — Umami module (optional) ──────────────────────────────────────
# Point at your own self-hosted Umami. Set UMAMI_ENABLED=true to turn the section on.
UMAMI_ENABLED=false
# Server-to-server URL (include Umami's base path if it runs under one, e.g. .../analytics).
UMAMI_BASEURL=http://umami:3000
UMAMI_USERNAME=
UMAMI_PASSWORD=
# Public origin the tracking script is served from (used to build the copy-paste snippet).
UMAMI_PUBLICURL=

# ── Social sign-in — ExternalAuth module (optional) ──────────────────────────
# Master switch. Leave false to keep only email-code / password sign-in.
EXTERNALAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Device trust (optional) ──────────────────────────────────────────────────
# true = a new device must be approved via an emailed code before it can call the API.
DEVICETRUST_ENFORCE=false
